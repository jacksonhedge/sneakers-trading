NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — waitlist confirmation emails. If unset, emails are silently skipped.
# Get a key at https://resend.com (free tier: 100/day, 3k/mo).
RESEND_API_KEY=
# Optional custom From address. Requires DNS records set up at Resend for the domain.
# Fallback sender is "Sneakers Terminal <onboarding@resend.dev>" which works without DNS.
WAITLIST_FROM_EMAIL=

# At-rest encryption key for user_provider_keys.api_key_encrypted (BYO LLM
# keys). Must decode to exactly 32 bytes (AES-256-GCM). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# If unset, secrets are stored as plaintext (with a startup warning) — fine
# for dev, NEVER in prod.
PROVIDER_KEY_ENCRYPTION_KEY=

# Dev-only escape hatch for testing the auth flow without depending on email
# delivery. When set to "1", /api/auth/login + /api/auth/request-link return
# the magic-link URL in the response body as `devLink`. NEVER set this in
# production — anyone calling the endpoint would get a sign-in URL for any
# email they submit.
AUTH_DEV_RETURN_LINK=
