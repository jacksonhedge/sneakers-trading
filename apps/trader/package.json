{
  "name": "@sneakers/trader",
  "version": "1.0.0",
  "description": "Prediction market trading bot with opportunity hunter and momentum analysis",
  "type": "module",
  "private": true,
  "main": "src/opportunity-hunter.ts",
  "scripts": {
    "hunter": "node --loader ts-node/esm src/opportunity-hunter.ts",
    "logger": "node --loader ts-node/esm src/market-data-logger.ts",
    "analyzer": "node --loader ts-node/esm src/outcome-analyzer.ts",
    "momentum": "node --loader ts-node/esm src/momentum-analyzer.ts",
    "log-outcome": "node --loader ts-node/esm src/log-outcome.ts",
    "bitcoin": "node --loader ts-node/esm src/bitcoin-analyzer.ts",
    "start": "tsx src/dashboard-server.ts",
    "dashboard": "tsx src/dashboard-server.ts",
    "crypto-hunter": "node --loader ts-node/esm src/crypto-com-opportunity-hunter.ts",
    "calibration": "node --loader ts-node/esm src/calibration-analyzer.ts",
    "correlations": "node --loader ts-node/esm src/market-correlation-analyzer.ts",
    "scrape:polymarket": "tsx src/scrapers/polymarket/scrape.ts",
    "scrape:kalshi": "tsx src/scrapers/kalshi/scrape.ts",
    "match:futures": "tsx src/scanner/match-futures.ts",
    "rank:overround": "tsx src/scanner/rank.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
