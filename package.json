{
  "name": "sneakers",
  "private": true,
  "version": "0.0.0",
  "description": "Autonomous multi-market trading agent — open source SDK + hosted platform",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "trader": "pnpm --filter=@sneakers/trader run",
    "hunter": "pnpm --filter=@sneakers/trader run hunter",
    "logger": "pnpm --filter=@sneakers/trader run logger",
    "analyzer": "pnpm --filter=@sneakers/trader run analyzer",
    "momentum": "pnpm --filter=@sneakers/trader run momentum",
    "log-outcome": "pnpm --filter=@sneakers/trader run log-outcome",
    "bitcoin": "pnpm --filter=@sneakers/trader run bitcoin",
    "dashboard": "pnpm --filter=@sneakers/trader run dashboard",
    "crypto-hunter": "pnpm --filter=@sneakers/trader run crypto-hunter",
    "calibration": "pnpm --filter=@sneakers/trader run calibration",
    "correlations": "pnpm --filter=@sneakers/trader run correlations"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
